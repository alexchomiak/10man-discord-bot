DISCORD_TOKEN=your_bot_token_here
# Optional: for instant command registration in one server
DISCORD_GUILD_ID=
# Optional: category where temp team voice channels will be created
TEAM_CATEGORY_ID=
# Optional: comma-separated random names for temporary team voice channels
TEAM_NAMES=Mirage,Inferno,Nuke,Ancient,Vertigo,Anubis,Dust2,Train
# Optional: minimum non-bot players required (must still be even count)
MIN_PLAYERS=4
# Optional: channel where daily CS2 notification message will be posted
NOTIFICATION_CHANNEL_ID=
# Optional: role mentioned in daily notification and managed by Subscribe/Unsubscribe buttons
NOTIFICATION_ROLE_ID=
# Optional: daily notification time in CST/CDT (America/Chicago) 24h format HH:MM
NOTIFICATION_TIME_CST=18:00
# Optional: sqlite database file path for persisted daily notification state
SQLITE_PATH=/app/data/bot.db
# Optional: MP3 file used for draft lobby music
LOBBY_MUSIC_PATH=/app/data/lobby.mp3
# Optional: set true for extra verbose voice/TTS diagnostics
AUDIO_DEBUG=false
